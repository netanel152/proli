{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "python $CLAUDE_PROJECT_DIR/.claude/hooks/pre-bash-guard.py", "timeout": 10}]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{"type": "command", "command": "python $CLAUDE_PROJECT_DIR/.claude/hooks/pre-edit-protect.py", "timeout": 10}]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{"type": "command", "command": "python $CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-format.py", "timeout": 30}]
      }
    ]
  }
}
