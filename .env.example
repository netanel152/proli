# ===========================================
# Proli WhatsApp CRM - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- WhatsApp (Green API) ---
GREEN_API_INSTANCE_ID=your_instance_id
GREEN_API_TOKEN=your_api_token

# --- Google Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key

# --- MongoDB ---
# For local Docker: mongodb://mongo:27017/proli_db
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/?appName=MyApp
MONGO_URI=mongodb://mongo:27017/proli_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://redis:6379/0

# --- Cloudinary (Image uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Admin Panel ---
# Generate with: python scripts/generate_admin_hash.py
ADMIN_PASSWORD_HASH=$2b$12$your_bcrypt_hash_here

# --- App Settings ---
ENVIRONMENT=development
LOG_LEVEL=INFO
TZ=Asia/Jerusalem
