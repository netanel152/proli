# =============================================================
# Proli — Environment Configuration Template
# Copy to .env and fill in real values before running.
# Never commit .env to version control.
# =============================================================

# -------------------------------------------------------------
# Green API (WhatsApp gateway) — REQUIRED
# Get from https://green-api.com/en/
# -------------------------------------------------------------
GREEN_API_INSTANCE_ID=your_instance_id_here
GREEN_API_TOKEN=your_api_token_here

# Webhook security token — set to a long random string (32+ chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_TOKEN=

# -------------------------------------------------------------
# Google Gemini AI — REQUIRED
# Get from https://aistudio.google.com/app/apikey
# -------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# AI model fallback chain (comma-separated, tried in order)
# AI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-1.5-flash

# -------------------------------------------------------------
# MongoDB — REQUIRED
# -------------------------------------------------------------
# Local dev: mongodb://localhost:27017/proli_db
# Docker:    mongodb://mongo:27017/proli_db (set via docker-compose env override)
# Atlas:     mongodb+srv://user:pass@cluster.mongodb.net/proli_db
MONGO_URI=mongodb://localhost:27017/proli_db

# Optional: separate test DB for integration tests
# MONGO_TEST_URI=mongodb://localhost:27017/proli_test_db

# Connection pool (tune for your server)
# MONGO_MAX_POOL_SIZE=100
# MONGO_MIN_POOL_SIZE=10

# -------------------------------------------------------------
# Redis — REQUIRED
# -------------------------------------------------------------
# Local dev: leave defaults
# Docker: set via docker-compose env override
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Full URL overrides HOST/PORT/DB if set
# REDIS_URL=redis://localhost:6379/0

# -------------------------------------------------------------
# Admin Panel — REQUIRED
# -------------------------------------------------------------
# Must be 8+ characters
ADMIN_PASSWORD=change_me_min_8_chars

# Admin phone (for SOS alerts and reports) — Israeli format without +
ADMIN_PHONE=972501234567

# Optional: pre-hashed bcrypt password (overrides ADMIN_PASSWORD)
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt()).decode())"
# ADMIN_PASSWORD_HASH=

# -------------------------------------------------------------
# Cloudinary (media storage) — REQUIRED for image/audio handling
# Get from https://cloudinary.com/console
# -------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# -------------------------------------------------------------
# Application settings — OPTIONAL
# -------------------------------------------------------------
ENVIRONMENT=production          # "production" or "development"
LOG_LEVEL=INFO
TIMEZONE=Asia/Jerusalem
MAX_CHAT_HISTORY=20

# CORS — comma-separated list of allowed origins (use * only in dev)
# BACKEND_CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# -------------------------------------------------------------
# AWS S3 Backup — OPTIONAL
# -------------------------------------------------------------
# BACKUP_S3_BUCKET=your-backup-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1

# -------------------------------------------------------------
# SMS Fallback (Inforu) — OPTIONAL
# -------------------------------------------------------------
# SMS_API_KEY=
# SMS_SENDER_ID=Proli
